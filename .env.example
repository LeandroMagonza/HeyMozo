# Database Configuration
DB_NAME=heymozo
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# JWT Authentication
JWT_SECRET=your-secure-development-jwt-secret

# API Configuration
REACT_APP_API_URL=http://localhost:3001/api

# Node Environment
NODE_ENV=development

# Email Configuration (Resend)
# Si RESEND_API_KEY no está seteado, los emails se loguean a consola en lugar de enviarse.
EMAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=

# Mercado Pago (Sprint 5 — pagos digitales)
# Usar credenciales de TEST mientras estés en sandbox. Pasar a credenciales productivas solo en deploy.
# Public Key — usada por el SDK MP del frontend (no es secreta).
REACT_APP_MP_PUBLIC_KEY=
# App ID — necesario para el OAuth redirect desde PaymentConfig (frontend lo arma como query param).
REACT_APP_MP_APP_ID=
# Access Token de la app — backend only, NUNCA exponer al frontend.
MP_ACCESS_TOKEN=
# App ID + App Secret — para el OAuth callback en /api/auth/mp/callback.
# En MP el client_secret del OAuth ES el mismo Access Token de la app (no es un secret aparte).
MP_APP_ID=
MP_APP_SECRET=

# URL base para construir el redirect URI del OAuth MP y la notification_url del webhook.
# Dev local con smoke MP: usar túnel ngrok (`ngrok http 3001` → "https://abc.ngrok-free.app").
# Prod: https://www.heymozo.com.ar
APP_BASE_URL=http://localhost:3001

# MP webhook signature secret (Sprint 5.6 — MP nativo).
# Se obtiene en MP devs panel → Tu app → Notificaciones → Configurar webhooks →
# pegar la URL `${APP_BASE_URL}/api/payments/mp/webhook` + marcar evento `Pagos` →
# copiar "Clave secreta" que MP te muestra. Sin esto el webhook rechaza todo con 401.
MP_WEBHOOK_SECRET=

# Escape hatch DEV-only: si `MP_SKIP_WEBHOOK_SIGNATURE=true` y NODE_ENV!=production,
# el webhook MP acepta sin verificar firma (loguea WARN). Útil para smoke local
# cuando el secret todavía no está sincronizado o quedó stale tras regenerar.
# **En prod la flag se ignora** — la firma SIEMPRE se verifica.
MP_SKIP_WEBHOOK_SIGNATURE=

# Marketplace MP (Sprint 5+, post-aprobación)
# Flag a nivel branch (Branch.mpMarketplaceEnabled, default false). Cuando MP apruebe el trámite
# Marketplace, activarlo per-branch desde la UI para habilitar split payment (consumo → venue,
# propina → MP del mozo). Mientras false, MP nativo cobra solo consumo (sin propina).
# No hay variable de entorno asociada — el control vive en DB.
