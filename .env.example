# Database Configuration
DB_NAME=heymozo
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# JWT Authentication
JWT_SECRET=your-secure-development-jwt-secret

# API Configuration
REACT_APP_API_URL=http://localhost:3001/api

# Node Environment
NODE_ENV=development

# Email Configuration (for testing - will log to console)
EMAIL_FROM=no-reply@heymozo.com

# Push Notifications (VAPID keys) - Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key_here
